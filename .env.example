# Application
APP_NAME=face-recognition-api
APP_ENV=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000

# Database - Set password once, URL is built automatically
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD  # Set a strong password for production!
POSTGRES_HOST=postgres  # Docker service name (use 'localhost' for local dev without Docker)
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_DB=facedb
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis - Set password once, URL is built automatically
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD  # Set a strong password for production!
REDIS_HOST=redis  # Docker service name (use 'localhost' for local dev without Docker)
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_TTL=3600

# Storage
STORAGE_BACKEND=local  # Options: local, s3
STORAGE_LOCAL_PATH=/app/data/images
STORAGE_S3_BUCKET=your-bucket-name
STORAGE_S3_REGION=us-east-1

# AWS Credentials (Required for AWS Rekognition and S3)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_REKOGNITION_COLLECTION_ID=faces-collection

# Face Recognition Provider - Smart Hybrid Mode
FACE_PROVIDER=insightface  # Using InsightFace for face recognition
USE_HYBRID_RECOGNITION=true
HYBRID_MODE=smart_hybrid  # Options: insightface_only, smart_hybrid, insightface_aws, aws_only
INSIGHTFACE_MODEL=antelopev2  # Options: buffalo_l (balanced), buffalo_s (faster), antelopev2 (best)
INSIGHTFACE_DET_SIZE=640  # Detection size - see guide below
SIMILARITY_THRESHOLD=0.6  # Minimum similarity for InsightFace (0.6-0.7 recommended, range: 0.0-1.0)

# Detection Size Guide:
# - 320: Fast, good for low-res webcams (480p-720p), real-time processing
# - 640: Balanced, recommended for most cases (720p-1080p cameras) ← DEFAULT
# - 1024: High accuracy, use for high-res cameras (1080p+), ~30% slower
# Rule of thumb: Use 640 for webcams/mobile, 1024 only if photos are consistently >1920px

# Smart Hybrid Confidence Thresholds
INSIGHTFACE_HIGH_CONFIDENCE=0.8  # High confidence - trust InsightFace immediately (0.8-1.0)
INSIGHTFACE_MEDIUM_CONFIDENCE=0.6  # Medium confidence - use local re-verification (0.6-0.8)
VECTOR_SEARCH_CANDIDATES=3  # Number of candidates from vector search before AWS verification
AWS_VERIFICATION_COUNT=3  # Number of top candidates to verify with AWS Rekognition

# Multi-Face Detection Settings
MULTIFACE_ENABLED=false  # Enable multi-face detection and recognition
FACE_DETECTION_METHOD=dnn  # Options: haar (fastest), dnn (balanced), insightface (accurate)
INSIGHTFACE_DETECTION_MODEL=buffalo_s  # InsightFace model for DETECTION only (buffalo_s recommended)
DETECTION_CONFIDENCE_THRESHOLD=0.5  # Minimum confidence for face detection (DNN/InsightFace only)
MAX_FACES_PER_FRAME=10  # Maximum number of faces to process per frame
MIN_FACE_SIZE=80  # Minimum face size in pixels (width or height)
FACE_CROP_PADDING=0.2  # Padding ratio around face bounding box (0.2 = 20%)
SAVE_ALL_DETECTED_FACES=true  # Save cropped images of all detected faces (not just matched)

# Region of Interest (ROI) Settings - For door/entrance scenarios
ROI_ENABLED=false  # Enable ROI filtering for multi-face detection
ROI_X=0.3  # ROI X position (normalized 0-1, 0.3 = 30% from left)
ROI_Y=0.2  # ROI Y position (normalized 0-1, 0.2 = 20% from top)
ROI_WIDTH=0.4  # ROI width (normalized 0-1, 0.4 = 40% of frame width)
ROI_HEIGHT=0.6  # ROI height (normalized 0-1, 0.6 = 60% of frame height)
ROI_MIN_OVERLAP=0.3  # Minimum overlap ratio for face to be in ROI (0.3 = 30%)

# Auto-Capture Settings
AUTO_CAPTURE_ENABLED=true  # Enable automatic capture of high-confidence recognition photos
AUTO_CAPTURE_CONFIDENCE_THRESHOLD=0.85  # Minimum confidence to auto-capture photo (0.0-1.0)
AUTO_CAPTURE_MAX_VERIFIED_PHOTOS=4  # Maximum verified photos to keep per person (FIFO stack)

# Webcam Settings
WEBCAM_ENABLED=false  # Enable webcam capture for face recognition
WEBCAM_DEVICE_ID=0  # Webcam device ID (0 for default camera)
WEBCAM_FPS=2  # Capture rate (frames per second)
WEBCAM_SUCCESS_COOLDOWN_SECONDS=5  # Seconds to wait after successful recognition before resuming
WEBCAM_API_URL=http://localhost:8000  # API URL for webcam daemon (use http://face.test for Traefik or production domain)

# Door Unlock Settings
DOOR_UNLOCK_PROVIDER=mock  # Options: mock, http, gpio
DOOR_UNLOCK_URL=http://door-controller/unlock  # HTTP endpoint for door unlock (when provider=http)
DOOR_UNLOCK_CONFIDENCE_THRESHOLD=0.85  # Minimum confidence to trigger door unlock (0.0-1.0)

# Access Logging Settings
ACCESS_LOG_OUTPUT=stdout  # Options: stdout, file, both
ACCESS_LOG_FILE_PATH=/var/log/face-recognition/access.log  # File path for access logs
ACCESS_LOG_FORMAT=json  # Options: json, text
ACCESS_LOG_INCLUDE_COOLDOWN_EVENTS=false  # Include cooldown status events in logs

# Security
SECRET_KEY=your-secret-key-change-in-production  # Used for x-face-token API authentication
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# IMPORTANT SECURITY NOTES:
# - POSTGRES_PASSWORD and REDIS_PASSWORD: Use strong, random passwords in production
# - NEVER expose database ports to the internet (removed from docker-compose.yaml)
# - All database access should be through the Docker network only

# Traefik / Frontend Basic Auth
DOMAIN=localhost  # Change to your domain in production (e.g., example.com)
BASIC_AUTH_USERNAME=admin  # Plain username
BASIC_AUTH_PASSWORD=changeme  # Plain password
ACME_EMAIL=admin@example.com  # Email for Let's Encrypt SSL certificates (production only)

# Logging
LOG_LEVEL=INFO

# CUDA/GPU Settings
# Docker always builds with GPU support (requirements-gpu.txt)
# Set INSIGHTFACE_CTX_ID to control GPU usage at runtime:
#   -1 = CPU only (for local dev/testing)
#    0 = Use GPU device 0 (for production)
INSIGHTFACE_CTX_ID=-1  # InsightFace context ID (-1 for CPU, 0+ for GPU device ID)
